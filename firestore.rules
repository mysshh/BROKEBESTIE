rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidExpense(data) {
      return data.userId is string && 
             data.amount is number && data.amount > 0 &&
             data.category is string && 
             data.date is string && 
             data.description is string &&
             data.createdAt is timestamp;
    }

    match /expenses/{expenseId} {
      allow list: if isSignedIn() && request.auth.uid != null;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidExpense(incoming()) && isValidId(expenseId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isOwner(incoming().userId) && isValidExpense(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
